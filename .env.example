# ================================================================
# ClearClause v3 — .env.local
# NEVER commit this file to GitHub — it's already in .gitignore
# ================================================================

# ── OpenAI (Legal Simplifier AI)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── Google Cloud TTS (replaces ElevenLabs)
# Setup steps:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or use existing)
# 3. Search "Cloud Text-to-Speech API" → Enable it
# 4. Go to APIs & Services → Credentials → + Create Credentials → API Key
# 5. Copy that key and paste it below
# FREE TIER: 4M characters/month (Standard), 1M/month (Neural2/WaveNet)
GOOGLE_TTS_API_KEY=AIza-your-google-api-key-here

# ── Supabase (Database & Auth)
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (Payments)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Stripe Price IDs
# Create products in Stripe Dashboard → Products → Add Product
# Then copy the Price ID (starts with price_) for each plan
STRIPE_PRICE_BASIC=price_replace_with_basic_monthly_id
STRIPE_PRICE_PRO=price_replace_with_pro_monthly_id
STRIPE_PRICE_BUSINESS=price_replace_with_business_monthly_id
STRIPE_PRICE_SINGLE=price_replace_with_single_use_id
STRIPE_PRICE_BUNDLE10=price_replace_with_10use_bundle_id
STRIPE_PRICE_BUNDLE30=price_replace_with_30use_bundle_id

# ── Site URL (change to your domain in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
